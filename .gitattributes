# Normalize all text files to LF in the repository.
# Developers on Windows still get CRLF in their working tree (text=auto),
# but the repository stores LF only.
* text=auto eol=lf

# Explicitly mark common text formats
*.py        text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.js        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.json      text eol=lf
*.csv       text eol=lf
*.sh        text eol=lf
*.lock      text eol=lf
*.cfg       text eol=lf
*.ini       text eol=lf
*.env       text eol=lf

# Binary files — no line-ending normalization
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.zip  binary
*.gz   binary
*.tar  binary
*.whl  binary
