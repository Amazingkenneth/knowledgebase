# Environment variable template — commit this file, never commit .env.
# Copy to .env and fill in your values.
# Loaded automatically by pydantic-settings on server startup (no `source` needed).
#
# Format:  KB_<SECTION>__<KEY>=value   (prefix KB_, nested delimiter __)
# Full schema: src/kb/config.py        Full docs: README.md § Configuration

# ── LLM / AI Chat (required to enable /api/v1/chat and /api/v1/extract) ───────
KB_LLM__API_KEY=sk-********************************   # DashScope — dashscope.aliyuncs.com (same key as embedding)
# KB_LLM__API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions  # default
# KB_LLM__MODEL=qwen-plus
# KB_LLM__MAX_TOKENS=1200

# ── Elasticsearch ─────────────────────────────────────────────────────────────
# KB_ES__URL=http://localhost:9200          # plain HTTP; docker-compose default
# KB_ES__USERNAME=elastic                   # only needed for secured clusters
# KB_ES__PASSWORD=                          # override instead of editing settings.yaml
# KB_ES__SSL_FINGERPRINT=                   # SHA-256 of the server TLS cert (HTTPS clusters)
# KB_ES__VERIFY_CERTS=false                 # set false for self-signed certs in dev
# KB_ES__ANALYZER_INDEX=cjk                 # fallback if IK plugin is not installed (default: ik_max_word)
# KB_ES__ANALYZER_QUERY=cjk                 # fallback if IK plugin is not installed (default: ik_smart)

# ── Embedding service (OpenAI-compatible API, e.g. DashScope) ────────────────
KB_EMBEDDING__API_KEY=sk-********************************   # DashScope — dashscope.aliyuncs.com
# KB_EMBEDDING__URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# KB_EMBEDDING__MODEL=text-embedding-v3
# KB_EMBEDDING__DIMS=1024
# KB_EMBEDDING__TIMEOUT_S=30

# ── Server ────────────────────────────────────────────────────────────────────
# KB_SERVER__PORT=8000                       # change to run multiple instances side-by-side
# KB_SERVER__HOST=0.0.0.0

# ── Search tuning ─────────────────────────────────────────────────────────────
# KB_SEARCH__STRICT_MAX_HITS=8             # results above this → TOO_MANY status
# KB_SEARCH__TITLE_BOOST=3.0              # title field weight vs body (BM25)
